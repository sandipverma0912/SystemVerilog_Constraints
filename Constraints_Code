Q18:Write a constraint to generate prime numbers between the range of 1 to 100.
Ans:
//---------- method-1 using constraint only ----------//
class cons;
  randc int num; //using randc to get all the prime numbers between 1 to 100.
  constraint range {num inside {[1:100]};}
  constraint value {num!=1;
                    (num==2) || num%2!=0;
                    (num==3) || num%3!=0;
                    (num==5) || num%5!=0;
                    (num==7) || num%7!=0;}
  function void post_randomize();
    $display("generate prime numbers = %0d",num);
  endfunction
endclass

module tb;
  cons c;
  initial begin
    c = new();
    repeat(30)
      c.randomize();
  end
endmodule

//---------- method-2 using function ----------//
class cons;
  rand int num;
  constraint range {num inside {[1:100]};}
  function int prime_num(int a);
    if(a<2)
      return 0;
    else if(a==2)
      return a;
    else begin
      for(int i=2; i<a; i++)begin
        if(a%i==0)
          return 0;
        else
          prime_num = a;
      end
    end
  endfunction
  
  function void post_randomize();
    if(prime_num(num))
    $display("prime number -> %0d[num=%0d]",prime_num(num),num);
  endfunction
endclass

module tb;
  cons c;
  initial begin
    c = new();
    repeat(100)
      c.randomize();
  end
endmodule





















